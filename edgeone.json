{
  "schedules": [
    {
      "name": "heartbeat",
      "cron": "*/5 * * * *",
      "path": "/api/v1/cron/heartbeat",
      "method": "GET"
    },
    {
      "name": "daily-cleanup",
      "cron": "0 2 * * *",
      "path": "/api/v1/cron/cleanup",
      "method": "POST",
      "payload": {
        "type": "daily",
        "dryRun": false
      },
      "timeout": 60
    }
  ]
}
