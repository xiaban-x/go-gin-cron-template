{
  "schedules": [
    {
      "name": "daily-cleanup",
      "cron": "0 2 * * *",
      "path": "/api/v1/cron/cleanup",
      "method": "POST",
      "payload": {
        "type": "daily",
        "dryRun": false
      }
    },
    {
      "name": "daily-report",
      "cron": "0 8 * * *",
      "path": "/api/v1/cron/report",
      "method": "POST",
      "payload": {
        "type": "daily"
      }
    },
    {
      "name": "daily-backup",
      "cron": "0 3 * * *",
      "path": "/api/v1/cron/backup",
      "method": "POST"
    },
    {
      "name": "daily-sync",
      "cron": "0 6 * * *",
      "path": "/api/v1/cron/sync",
      "method": "POST"
    },
    {
      "name": "daily-analytics",
      "cron": "0 9 * * *",
      "path": "/api/v1/cron/analytics",
      "method": "POST"
    }
  ]
}
